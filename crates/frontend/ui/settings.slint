// Settings window: BIOS startup mode plus keyboard/controller remapping.
//
// The Rust side fills the persisted settings and `rows` (one per WonderSwan
// button). Rebinding a key works by capture: clicking a keyboard cell returns
// focus to the FocusScope and arms capture; the next key press fires
// `key-captured`. Controller capture is polled on the Rust side while
// `rebind-pad` is armed.

import { Button, CheckBox, Palette, ScrollView, VerticalBox, HorizontalBox } from "std-widgets.slint";

export struct BindingRow {
    label: string,
    key: string,
    pad: string,
}

component SectionButton inherits Rectangle {
    in property <string> text;
    in property <bool> selected;
    callback clicked();

    height: 44px;
    background: root.selected ? Palette.control-background : transparent;

    Text {
        x: 16px;
        width: parent.width - 32px;
        height: parent.height;
        text: root.text;
        font-size: 14px;
        vertical-alignment: center;
        color: Palette.foreground;
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}

component BiosCheckBox inherits Rectangle {
    in property <string> text;
    in property <bool> checked;
    callback clicked();

    height: 30px;

    CheckBox {
        width: parent.width;
        height: parent.height;
        text: root.text;
        checked: root.checked;
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}

export component SettingsWindow inherits Window {
    // 0 = disabled/direct boot, 1 = WonderSwan, 2 = WonderSwan Color, 3 = SwanCrystal.
    in property <int> bios-rom-mode;
    in property <[BindingRow]> rows;
    // Non-empty while waiting for a key/button, e.g. "Press a key for A...".
    in property <string> listening-hint;
    in property <bool> rotate-input-with-screen;

    out property <int> selected-section: 0;
    private property <length> button-column-width: 72px;

    callback set-bios-rom-mode(int);
    callback set-rotate-input-with-screen(bool);
    callback open-rom-directory();
    callback rebind-key(int);
    callback rebind-pad(int);
    // Fired for every key press while the window has focus; Rust ignores it
    // unless a keyboard rebind is armed.
    callback key-captured(string);
    callback reset-defaults();
    callback close-settings();

    title: "Swanium - Settings";
    icon: @image-url("../../../assets/icons/AppIcon.png");
    min-width: 760px;
    max-width: 760px;
    preferred-width: 760px;
    min-height: 520px;
    max-height: 32767px;
    preferred-height: 640px;
    forward-focus: scope;

    scope := FocusScope {
        key-pressed(event) => {
            root.key-captured(event.text);
            accept
        }

        HorizontalLayout {
            spacing: 0px;

            Rectangle {
                width: 210px;
                background: Palette.alternate-background;

                VerticalLayout {
                    spacing: 0px;

                    Rectangle {
                        height: 68px;
                        background: Palette.alternate-background;
                        Text {
                            x: 16px;
                            width: parent.width - 32px;
                            height: parent.height;
                            text: "Swanium Settings";
                            font-size: 20px;
                            vertical-alignment: center;
                            color: Palette.foreground;
                        }
                    }

                    SectionButton {
                        text: "ROM";
                        selected: root.selected-section == 0;
                        clicked => { root.selected-section = 0; }
                    }
                    SectionButton {
                        text: "Input";
                        selected: root.selected-section == 1;
                        clicked => { root.selected-section = 1; }
                    }
                }
            }

            Rectangle {
                width: 1px;
                background: Palette.border;
            }

            Rectangle {
                background: Palette.background;
                horizontal-stretch: 1;

                VerticalLayout {
                    padding: 24px;
                    spacing: 12px;

                    if root.selected-section == 0: VerticalBox {
                        spacing: 16px;
                        vertical-stretch: 1;

                        Text {
                            text: "ROM";
                            font-size: 24px;
                            font-weight: 700;
                            color: Palette.foreground;
                        }
                        Text {
                            text: "BIOS ROM";
                            font-size: 16px;
                            font-weight: 700;
                            color: Palette.foreground;
                        }
                        VerticalBox {
                            BiosCheckBox {
                                text: "Direct boot without BIOS";
                                checked: root.bios-rom-mode == 0;
                                clicked => { root.set-bios-rom-mode(0); }
                            }
                            BiosCheckBox {
                                text: "WonderSwan";
                                checked: root.bios-rom-mode == 1;
                                clicked => { root.set-bios-rom-mode(1); }
                            }
                            BiosCheckBox {
                                text: "WonderSwan Color";
                                checked: root.bios-rom-mode == 2;
                                clicked => { root.set-bios-rom-mode(2); }
                            }
                            BiosCheckBox {
                                text: "SwanCrystal";
                                checked: root.bios-rom-mode == 3;
                                clicked => { root.set-bios-rom-mode(3); }
                            }
                        }

                        HorizontalBox {
                            alignment: start;
                            Button {
                                text: "Open ROM Directory";
                                clicked => { root.open-rom-directory(); }
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                        }
                    }

                    if root.selected-section == 1: VerticalBox {
                        spacing: 12px;
                        vertical-stretch: 1;

                        Text {
                            text: "Input";
                            font-size: 24px;
                            font-weight: 700;
                            color: Palette.foreground;
                        }
                        Rectangle {
                            height: 34px;
                            horizontal-stretch: 1;

                            CheckBox {
                                width: parent.width;
                                height: parent.height;
                                text: "Rotate directional input with screen";
                                checked: root.rotate-input-with-screen;
                                toggled => {
                                    root.set-rotate-input-with-screen(self.checked);
                                }
                            }
                        }
                        HorizontalLayout {
                            alignment: stretch;
                            spacing: 12px;
                            Text { text: "Button"; width: root.button-column-width; font-weight: 700; color: Palette.foreground; }
                            Text {
                                text: "Keyboard";
                                horizontal-stretch: 1;
                                min-width: 0px;
                                font-weight: 700;
                                color: Palette.foreground;
                            }
                            Text {
                                text: "Controller";
                                horizontal-stretch: 1;
                                min-width: 0px;
                                font-weight: 700;
                                color: Palette.foreground;
                            }
                        }
                        ScrollView {
                            viewport-height: root.rows.length * 56px;
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            rows-grid := GridLayout {
                                width: parent.visible-width;
                                spacing: 12px;
                                for row[i] in root.rows: Row {
                                    Text {
                                        text: row.label;
                                        width: root.button-column-width;
                                        height: 44px;
                                        vertical-alignment: center;
                                        color: Palette.foreground;
                                    }
                                    Rectangle {
                                        horizontal-stretch: 1;
                                        min-width: 0px;
                                        height: 44px;
                                        Button {
                                            text: row.key;
                                            y: 7px;
                                            width: parent.width;
                                            height: 30px;
                                            clicked => {
                                                scope.focus();
                                                root.rebind-key(i);
                                            }
                                        }
                                    }
                                    Rectangle {
                                        horizontal-stretch: 1;
                                        min-width: 0px;
                                        height: 44px;
                                        Button {
                                            text: row.pad;
                                            y: 7px;
                                            width: parent.width;
                                            height: 30px;
                                            clicked => { root.rebind-pad(i); }
                                        }
                                    }
                                }
                            }
                        }
                        Text {
                            text: root.listening-hint;
                            color: #d0a020;
                            height: 20px;
                        }
                    }

                    if root.selected-section == 1: HorizontalBox {
                        alignment: end;
                        Button {
                            text: "Reset Input Defaults";
                            clicked => { root.reset-defaults(); }
                        }
                    }
                }
            }
        }
    }
}
